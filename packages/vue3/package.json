{
  "name": "@lcap/vue3-template",
  "version": "2.2.0",
  "description": "base on vue3",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "rspack build --config ./build/rspack.config.js && node ./scripts/build.js",
    "deploy": "node ./scripts/deploy.js",
    "postbuild": "npm run zip",
    "zip": "node ./scripts/zip.js"
  },
  "keywords": [
    "lcap",
    "lcap-template"
  ],
  "license": "MIT",
  "dependencies": {
    "@lcap/basic-template": "workspace:*",
    "@lcap/ui-libraries-mcp": "./source/lcap_modules/@lcap/ui-libraries-mcp@0.0.5/zip.tgz",
    "pinia": "2.3.1",
    "vue": "3.5.13",
    "vue-router": "4.5.0",
    "vue-i18n": "11.1.2",
    "date-fns": "2.30.0",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "fs-extra": "^9.0.0",
    "@rspack/cli": "1.3.10",
    "@rspack/core": "1.3.10",
    "vue-loader": "17.4.2"
  }
}
