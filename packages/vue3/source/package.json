{
  "name": "vue3-template",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node ./scripts/postinstall.js",
    "dev": "rspack dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 rspack build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "prepare": "husky",
    "lint:style": "stylelint ./src/**/*.css",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0 && node scripts/format-changelog.js",
    "git-cz": "git-cz --disable-emoji"
  },
  "dependencies": {
    "pinia": "2.3.1",
    "vue": "3.5.13",
    "vue-router": "4.5.0",
    "vue-i18n": "11.1.2",
    "date-fns": "2.30.0",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "@tsconfig/node22": "22.0.0",
    "@types/node": "22.10.2",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.5.0",
    "@vue/tsconfig": "0.7.0",
    "cross-env": "7.0.3",
    "eslint": "9.22.0",
    "eslint-plugin-vue": "10.0.0",
    "npm-run-all2": "7.0.2",
    "prettier": "3.5.3",
    "typescript": "5.7.3",
    "vue-tsc": "2.1.10",
    "@rspack/cli": "1.3.10",
    "@rspack/core": "1.3.10",
    "vue-loader": "17.4.2",
    "tar": "7.4.3"
  },
  "optionalDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "conventional-changelog": "7.1.1",
    "conventional-changelog-cli": "5.0.0",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "husky": "9.1.7",
    "git-cz": "4.9.0",
    "stylelint": "16.23.0",
    "stylelint-config-standard": "39.0.0"
  },
  "lcap_modules": {
    "@lcap/ui-libraries-mcp": "./lcap_modules/@lcap/ui-libraries-mcp@0.0.3/zip.tgz",
    "@lcap/swc-plugin-import": "./lcap_modules/@lcap/swc-plugin-import@0.0.1/zip.tgz"
  }
}
